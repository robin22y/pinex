# Copy to `.env` or `.env.local` and fill in (never commit secrets).
# Vite exposes only variables prefixed with VITE_ to client code.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_ADSENSE_CLIENT=
VITE_SUPERADMIN_EMAIL=

# Telegram bot username (no leading @). Used by the frontend to build
# the "Connect Telegram" deeplink and by scripts/send_telegram_invite_
# email.py for the email body. Defaults to "pinex_Alerts_bot" if unset.
# The frontend default lives in src/lib/siteMeta.js — keep them in
# sync if you change the bot.
# TELEGRAM_BOT_USERNAME=pinex_Alerts_bot
