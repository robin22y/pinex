# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Root env (Vite); never commit API keys or Supabase URLs
.env
.env.local

# Netlify serverless secrets
netlify/functions/.env

# Local script secrets
scripts/.env
scripts/service_account.json
scripts/__pycache__/
**/__pycache__/
*.py[cod]

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code local metadata
.claude/

# Local Netlify folder
.netlify

# Dedup log for the one-time Telegram invite email script. Contains
# the personal email addresses of recipients who've been emailed —
# must never be committed. (Already matched by *.log above but
# called out explicitly so a maintainer doesn't accidentally
# re-broaden the *.log rule and lose this protection.)
scripts/.sent_telegram_invite_emails.log
logs/*.log
