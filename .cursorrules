# NUMBER FORMATTING
const formatCr = (n) => {
  if (!n) return '—'
  if (n >= 100000) return (n/100000).toFixed(1) + 'L Cr'
  if (n >= 1000) return (n/1000).toFixed(0) + 'K Cr'  
  return n.toFixed(0) + ' Cr'
}

const formatPrice = (n) => {
  if (!n) return '—'
  return '₹' + n.toLocaleString('en-IN', 
    {maximumFractionDigits: 2})
}

const formatPct = (n, decimals=1) => {
  if (n == null) return '—'
  return (n > 0 ? '+' : '') + n.toFixed(decimals) + '%'
}

# DELIVERY INTERPRETATION
Delivery % falling + Volume rising + Stage 2
= BREAKOUT SIGNATURE (show in blue, not red)
This is NOT a warning — it means momentum 
traders are joining existing accumulation.

Only flag delivery decline as WARNING when:
- Stage 3 or Stage 4 AND delivery falling
- OR price also falling with delivery

